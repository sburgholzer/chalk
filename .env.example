# =============================================================================
# Chalk Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit real secrets.
# =============================================================================

# =============================================================================
# LOCAL DEV (needed for `npm run dev`)
# =============================================================================

# API URL from CDK output: ApiUrl
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# Cognito hosted UI domain (configure in Cognito console after deploy)
NEXT_PUBLIC_COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com

# Same value as COGNITO_CLIENT_ID below
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-cognito-client-id

# OAuth redirect (localhost for dev)
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/login

# Cognito group name for your team
NEXT_PUBLIC_TEAM_ID=your-team-group-name

# =============================================================================
# LAMBDA RUNTIME (injected by CDK, only needed locally if calling AWS directly)
# =============================================================================

AWS_REGION=us-east-1

# Bedrock model IDs
BEDROCK_CLAUDE_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_TITAN_MODEL_ID=amazon.titan-embed-text-v2:0

# DynamoDB table (auto-created by CDK)
CHALK_TABLE_NAME=ChalkTable

# S3 bucket for diagrams + ADR exports (from CDK output: BucketName)
CHALK_BUCKET_NAME=chalk-bucket-YOUR_ACCOUNT_ID

# Cognito (from CDK outputs: UserPoolId, UserPoolClientId)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_REGION=us-east-1
